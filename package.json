{
  "name": "vue3-base",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "16.15.0"
  },
  "scripts": {
    "test": "run-s test:*",
    "serve": "vue-cli-service serve",
    "build": "vue-cli-service build",
    "test:eslint": "eslint './src/**/*.{js,jsx,vue}'",
    "autofix:eslint": "eslint --fix './src/**/*.{js,jsx,vue}'",
    "autofix:prettier": "prettier --write './src/**/*.{js,jsx,vue}'",
    "prepare": "husky install",
    "pre-commit": "lint-staged"
  },
  "dependencies": {
    "@vueup/vue-quill": "^1.0.0",
    "@vueuse/core": "^9.6.0",
    "axios": "^0.27.2",
    "core-js": "^3.6.5",
    "dayjs": "^1.11.5",
    "husky": ">=6",
    "js-cookie": "^3.0.1",
    "npm-run-all": "^4.1.5",
    "vue": "^3.0.0",
    "vue-router": "^4.0.0-0",
    "vuex": "^4.1.0"
  },
  "devDependencies": {
    "@vue/cli-plugin-babel": "~4.5.13",
    "@vue/cli-plugin-eslint": "~4.5.13",
    "@vue/cli-plugin-router": "~4.5.13",
    "@vue/cli-plugin-vuex": "~4.5.13",
    "@vue/cli-service": "~4.5.13",
    "@vue/compiler-sfc": "^3.0.0",
    "@vue/eslint-config-prettier": "^6.0.0",
    "babel-eslint": "^10.1.0",
    "eslint": "^6.8.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-prettier": "^3.3.1",
    "eslint-plugin-vue": "^7.0.0",
    "lint-staged": "^13.0.4",
    "prettier": "^2.2.1",
    "sass": "^1.55.0",
    "sass-loader": "^10.3.1"
  },
  "lint-staged": {
    "*.{js,jsx,vue}": "eslint --fix src/",
    "*.{js,jsx,vue,json,css,md}": "prettier --write",
    "*.js": "eslint --cache --fix"
  }
}
